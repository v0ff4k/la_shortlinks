REDIS_HOST=ls_sl-redis
REDIS_URL=null
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PORT=6379
REDIS_CLIENT=phpredis
REDIS_CLUSTER=redis
